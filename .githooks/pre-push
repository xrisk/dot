#!/usr/bin/env bash
set -e

echo "🔍 Scanning push history for secrets..."

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

tmpfiles=()

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip deletions
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  # Commits to scan: fall back to --not --remotes when remote SHA is unknown locally
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ] || \
     ! git cat-file -e "$remote_sha" 2>/dev/null; then
    commits=$(git log --format="%H" "$local_sha" --not --remotes)
  else
    commits=$(git log --format="%H" "$remote_sha..$local_sha")
  fi
  [ -z "$commits" ] && continue

  while IFS= read -r commit; do
    files=$(git diff-tree --no-commit-id -r --name-only --diff-filter=ACM "$commit" \
      | grep -v -E '^(nvim/lazy-lock\.json|\.secrets\.baseline)$' || true)
    [ -z "$files" ] && continue

    while IFS= read -r file; do
      safe="$tmpdir/${commit:0:8}__$(echo "$file" | tr '/' '__')"
      git show "$commit:$file" > "$safe" 2>/dev/null || continue
      tmpfiles+=("$safe")
    done <<< "$files"
  done <<< "$commits"
done

if [ ${#tmpfiles[@]} -eq 0 ]; then
  echo "✅ No files to scan."
  exit 0
fi

scan_out="$tmpdir/scan.json"
uvx detect-secrets scan "${tmpfiles[@]}" \
  --exclude-files 'nvim/lazy-lock\.json' > "$scan_out" 2>/dev/null

# Guard: if output is empty or not valid JSON, fail safe
if [ ! -s "$scan_out" ]; then
  echo "⚠️  detect-secrets produced no output — skipping scan."
  exit 0
fi

python3 - "$tmpdir" "$scan_out" << 'PYEOF'
import json, sys, os

tmpdir, scan_out = sys.argv[1], sys.argv[2]
with open(scan_out) as f:
    data = json.load(f)

findings = data.get("results", {})
if not findings:
    sys.exit(0)

for path, hits in findings.items():
    fname = os.path.basename(path)
    commit = fname[:8]
    orig = fname[10:].replace("__", "/")
    for h in hits:
        print(f"  commit {commit} — {orig}:{h['line_number']} — {h['type']}")
sys.exit(1)
PYEOF

if [ $? -ne 0 ]; then
  echo "❌ Secrets detected in commit history — push blocked."
  echo ""
  echo "Rewrite history to remove the secret (e.g. with git-filter-repo), then re-push."
  echo "If a false positive, update the baseline:"
  echo "  uvx detect-secrets scan --all-files --exclude-files 'nvim/lazy-lock.json' > .secrets.baseline"
  echo "  git add .secrets.baseline && git commit"
  exit 1
fi

echo "✅ No secrets found."
